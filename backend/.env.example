# Daily operation note:
# Groww trading API sessions reset every morning after 6 AM IST.
# Re-approve your trading API session in the Groww dashboard before market open.

# ── Groww API ──────────────────────────────────────────────────────────────
GROWW_API_KEY=your_groww_trading_api_key
GROWW_API_SECRET=your_groww_trading_api_secret
GROWW_ACCESS_TOKEN=
GROWW_BASE_URL=https://api.groww.in

# ── LLM Provider ───────────────────────────────────────────────────────────
# Options: anthropic | bedrock
LLM_PROVIDER=anthropic

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Required when LLM_PROVIDER=bedrock
# Recommended: configure AWS credentials via `aws configure`
AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ── Trading Mode ───────────────────────────────────────────────────────────
# paper = real market data + simulated orders
# live  = real exchange orders
MODE=paper

# ── Database ───────────────────────────────────────────────────────────────
# Supported:
# DATABASE_URL=sqlite:///./trading.db
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./trading.db

# ── Telegram Notifications ────────────────────────────────────────────────
# Get token from @BotFather on Telegram
# Get chat_id by messaging your bot, then checking:
# https://api.telegram.org/bot{TOKEN}/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
